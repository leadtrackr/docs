{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "LeadTrackr",
  "colors": {
    "primary": "#51B483",
    "light": "#FAFFFC",
    "dark": "#3E8762"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "getting-started/create-account-and-project",
              "getting-started/add-members",
              "getting-started/rate-and-process-leads",
              "getting-started/invoices"
            ]
          },
          {
            "group": "Lead Sources",
            "pages": [
              "lead-sources/wordpress-forms",
              "lead-sources/gtm",
              "lead-sources/server-side-gtm",
              "lead-sources/channel-flow-tracker"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/ga4",
              "integrations/google-ads",
              "integrations/meta"
            ]
          },
          {
            "group": "Conversion Labels",
            "pages": [
              "conversion-labels/set-up-conversion-labels",
              "conversion-labels/structure-conversion-labels"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://app.leadtrackr.io",
          "icon": "gauge"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/dark.svg",
    "dark": "/logo/light.svg",
    "href": "https://leadtrackr.io/"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@leadtrackr.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.leadtrackr.io"
    }
  },
  "footer": {
    "socials": {}
  },
  "fonts": {
    "family": "Cairo",
    "weight": 400,
    "source": "https://fonts.googleapis.com/css2",
    "format": "woff"
  },
  "banner": {
    "dismissible": false
  }
}
